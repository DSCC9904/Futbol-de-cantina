# .env.example
# ─────────────────────────────────────────────────────────────────
# Este archivo es una PLANTILLA. Nunca contiene contraseñas reales.
# Para usarlo:
#   1. Copia este archivo y renómbralo a ".env"
#   2. Llena los valores reales en ".env"
#   3. NUNCA subas ".env" a internet (ya está protegido por .gitignore)
# ─────────────────────────────────────────────────────────────────

# Cuando conectes la API de fútbol (Milestone 2), pon tu clave aquí:
API_FOOTBALL_KEY=tu_clave_aqui

# Si en el futuro usas Resend para enviar correos automáticos:
RESEND_API_KEY=tu_clave_aqui
